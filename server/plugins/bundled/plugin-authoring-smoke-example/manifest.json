{
  "id": "plugin-authoring-smoke-example",
  "apiVersion": 1,
  "version": "0.1.0",
  "displayName": "Plugin Authoring Smoke Example",
  "description": "Minimal plugin fixture for authoring and SDK compatibility smoke tests.",
  "author": "Octopus",
  "categories": ["example", "authoring"],
  "capabilities": [
    "plugin.state.read",
    "plugin.state.write",
    "events.subscribe",
    "ui.dashboardWidget.register"
  ],
  "entrypoints": {
    "worker": "./dist/worker.js",
    "ui": "./dist/ui"
  },
  "ui": {
    "slots": [
      {
        "type": "dashboardWidget",
        "id": "authoring-smoke-widget",
        "displayName": "Authoring Smoke",
        "exportName": "AuthoringSmokeWidget"
      }
    ]
  }
}
