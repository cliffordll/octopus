{
  "id": "git.local",
  "apiVersion": 1,
  "version": "0.1.0",
  "displayName": "Git",
  "description": "本地 Git 工作流工具，只能操作 runtime 分配的 workspace cwd。",
  "author": "Octopus",
  "categories": ["workspace", "git"],
  "capabilities": [
    "agent.tools.register",
    "project.workspaces.read"
  ],
  "entrypoints": {
    "worker": "./dist/worker.js"
  },
  "tools": [
    {
      "name": "git.status",
      "displayName": "查看状态",
      "description": "查看当前 runtime workspace 仓库的分支和未提交改动。",
      "parametersSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "git.diff",
      "displayName": "查看差异",
      "description": "查看当前 runtime workspace 仓库的未暂存或已暂存 diff。",
      "parametersSchema": {
        "type": "object",
        "properties": {
          "staged": { "type": "boolean" },
          "pathspec": { "type": "string" }
        }
      }
    },
    {
      "name": "git.log",
      "displayName": "查看提交记录",
      "description": "查看当前 runtime workspace 仓库的最近提交。",
      "parametersSchema": {
        "type": "object",
        "properties": {
          "limit": { "type": "integer", "minimum": 1, "maximum": 50 }
        }
      }
    },
    {
      "name": "git.branch.list",
      "displayName": "查看分支",
      "description": "列出当前 runtime workspace 仓库的本地分支。",
      "parametersSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "git.branch.create",
      "displayName": "创建分支",
      "description": "在当前 runtime workspace 仓库创建本地分支。需要 confirm=true。",
      "parametersSchema": {
        "type": "object",
        "required": ["branchName", "confirm"],
        "properties": {
          "branchName": { "type": "string" },
          "startPoint": { "type": "string" },
          "confirm": { "type": "boolean", "const": true }
        }
      }
    },
    {
      "name": "git.commit",
      "displayName": "提交代码",
      "description": "在当前 runtime workspace 仓库创建 commit。需要 confirm=true。",
      "parametersSchema": {
        "type": "object",
        "required": ["message", "confirm"],
        "properties": {
          "message": { "type": "string" },
          "stageAll": { "type": "boolean" },
          "confirm": { "type": "boolean", "const": true }
        }
      }
    },
    {
      "name": "git.push",
      "displayName": "推送代码",
      "description": "推送当前 runtime workspace 仓库。需要 confirm=true。",
      "parametersSchema": {
        "type": "object",
        "required": ["confirm"],
        "properties": {
          "remote": { "type": "string" },
          "branch": { "type": "string" },
          "setUpstream": { "type": "boolean" },
          "confirm": { "type": "boolean", "const": true }
        }
      }
    },
    {
      "name": "git.worktree.create",
      "displayName": "创建 worktree",
      "description": "在当前 runtime workspace 仓库的 .octopus/worktrees 下创建 git worktree。需要 confirm=true。",
      "parametersSchema": {
        "type": "object",
        "required": ["branchName", "confirm"],
        "properties": {
          "branchName": { "type": "string" },
          "startPoint": { "type": "string" },
          "confirm": { "type": "boolean", "const": true }
        }
      }
    }
  ]
}
